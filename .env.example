NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

MONGO_URI=mongodb://127.0.0.1:27017/sidequestz-backend

JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Resend (https://resend.com) — required in production for OTP emails
RESEND_API_KEY=
# Verified sender in Resend (e.g. Sidequestz <onboarding@resend.dev> for testing)
MAIL_FROM=Sidequestz <onboarding@resend.dev>
OTP_EXPIRES_MINUTES=10
